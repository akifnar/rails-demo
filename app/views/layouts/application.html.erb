<!DOCTYPE html>
<html class="catalog-button">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Pragprog Things Online Store"%></title>
    <meta name = "viewport" content = "width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag%>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags%>
  </head>
  <body>
    <header class="bg-green-700" >
      <%= image_tag 'logo.svg',class:"w-70 h-35", alt: 'The Pragmatic Things'%>
      <h1><%= @page_title %></h1>
    </header>

    <section class="flex">
      <nav class="bg-green-900 p-6">
        
        <%= render partial: 'layouts/cart', locals: {cart: @cart}%>

        
        <%=current_time %>
        <ul class="text-gray-300 leading-8">
          <% if @session_counter && @session_counter > 5 %>
            <li class = "text-white whitespace-nowrap">Visit No: <%= @session_counter.ordinalize %> Still thinking about it ? </li>
          <%end%>
          <li><%= link_to 'Home', store_index_path %></li>
          <li><a href="/questions">Questions</a></li>
          <li><a href="/news">News</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><%= link_to 'Carts', carts_path %></li>
        </ul>
      </nav>

      <main class="container mx-auto mt-4 px-5 flex">
        <%= yield %>
      </main>
    </section>
  </body>
</html>
